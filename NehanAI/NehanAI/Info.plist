<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_TOKEN</key>
	<string>$(API_TOKEN)</string>
	<key>WORKER_URL</key>
	<string>$(WORKER_URL)</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>nehan.aiが訪問場所をライフログとして記録します</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>nehan.aiが現在地を記録します</string>
	<key>NSHealthShareUsageDescription</key>
	<string>nehan.aiが睡眠・歩数・心拍・マインドフルネスなどのデータを日報に記録します</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>nehan.aiが気分・カフェイン・飲水・歯磨き・手洗い・頭痛などの記録をヘルスケアに保存します</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>ブログの書き忘れをお知らせします</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>ai.aicu.nehan.sync</string>
		<string>ai.aicu.nehan.sleep</string>
		<string>ai.aicu.nehan.blogpublish</string>
	</array>
</dict>
</plist>
